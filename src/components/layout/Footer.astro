---
import { site } from '@data/site';
const year = new Date().getFullYear();
---
<footer class="mt-16 border-t-2 border-ink bg-sand px-4 py-8">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-wrap items-start justify-between gap-8">
      <div>
        <p class="font-display text-4xl font-black uppercase text-ink leading-none">
          <span class="masthead-x">X</span>perten Insider
        </p>
        <p class="mt-1 font-sans text-xs text-ink-muted uppercase tracking-widest">{site.tagline}</p>
      </div>

      <div class="font-sans text-xs text-ink-muted space-y-1">
        <p class="font-bold uppercase tracking-widest text-ink">Navigation</p>
        {site.nav.map((item) => (
          <p><a href={item.href} class="hover:text-green transition-colors">{item.label}</a></p>
        ))}
      </div>

      <div class="font-sans text-xs text-ink-muted space-y-1">
        <p class="font-bold uppercase tracking-widest text-ink">Rechtliches</p>
        <p><a href="/impressum" class="hover:text-green transition-colors">Impressum</a></p>
        <p><a href="/datenschutz" class="hover:text-green transition-colors">Datenschutz</a></p>
      </div>
    </div>

    <div class="mt-8 border-t border-rule pt-4 flex justify-between items-center">
      <p class="font-sans text-xs text-ink-muted">© {year} {site.name} — Alle Rechte vorbehalten.</p>
      <p class="font-display text-2xl font-black text-ink-muted opacity-20">{year}</p>
    </div>
  </div>
</footer>
