---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import { site } from '@data/site';
import { readingTime } from '@lib/reading-time';

export async function getStaticPaths() {
  const articles = (await getCollection('blog')).filter((a) => a.data.freigabe);
  return articles.map((a) => ({ params: { slug: a.id }, props: { entry: a } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content, headings } = await render(entry);

const lesezeit = readingTime(entry.body ?? '');

const datumFormatiert = d.datum.toLocaleDateString('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

// Verwandte Artikel (gleiche Kategorie)
const alle = (await getCollection('blog')).filter(
  (a) => a.data.freigabe && a.id !== entry.id && a.data.kategorie === d.kategorie
).slice(0, 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.description,
  datePublished: d.datum.toISOString().slice(0, 10),
  dateModified: d.datum.toISOString().slice(0, 10),
  author: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${site.url}/blog/${entry.id}`,
  },
  inLanguage: 'de-DE',
  articleSection: d.kategorie,
  timeRequired: `PT${lesezeit}M`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site.url}/blog` },
    { '@type': 'ListItem', position: 3, name: d.title, item: `${site.url}/blog/${entry.id}` },
  ],
};
---
<BaseLayout
  title={d.title}
  description={d.description}
  path={`/blog/${entry.id}`}
  type="article"
  datum={d.datum}
  autor={d.autor}
  schema={[articleSchema, breadcrumbSchema]}
>
  <Header />

  <main class="mx-auto max-w-7xl px-4 py-8">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="font-sans text-xs text-ink-muted mb-6 flex gap-2 uppercase tracking-widest">
      <a href="/" class="hover:text-green transition-colors">Start</a>
      <span aria-hidden="true">/</span>
      <a href="/blog" class="hover:text-green transition-colors">Blog</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink">{d.kategorie}</span>
    </nav>

    <!-- Header-Bild -->
    {d.bild && (
      <div class="mb-8 overflow-hidden border border-rule">
        <img
          src={d.bild}
          alt={d.bildAlt ?? d.title}
          width={1200}
          height={630}
          loading="eager"
          decoding="async"
          class="w-full object-cover h-64 md:h-96 grayscale"
        />
      </div>
    )}

    <!-- Artikel Header -->
    <div class="border-b-2 border-ink pb-6 mb-8">
      <p class="kicker mb-2">{d.kategorie}</p>
      <h1 style="font-family:'Barlow Condensed',Impact,sans-serif;font-weight:900;text-transform:uppercase;letter-spacing:-0.02em;line-height:0.92;" class="text-[clamp(2rem,6vw,5rem)] text-ink">
        {d.title}
      </h1>
      <div class="mt-3 flex flex-wrap gap-4 font-sans text-xs text-ink-subtle uppercase tracking-widest">
        <span>{d.autor}</span>
        <span>—</span>
        <time datetime={d.datum.toISOString().slice(0,10)}>{datumFormatiert}</time>
        <span>—</span>
        <span>{lesezeit} Min. Lesezeit</span>
      </div>
      <p class="mt-4 font-sans text-base text-ink-muted leading-relaxed max-w-2xl">
        {d.description}
      </p>
    </div>

    <!-- Artikel + Sidebar -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0">

      <!-- Content -->
      <div class="md:col-span-2 md:border-r md:border-rule md:pr-8">
        <div class="prose-news">
          <Content />
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="md:pl-8 mt-8 md:mt-0 space-y-8">

        <!-- Inhaltsverzeichnis -->
        {headings.length > 0 && (
          <div>
            <div class="border-b-2 border-ink pb-2 mb-4">
              <p class="font-sans text-xs font-bold uppercase tracking-widest">Inhalt</p>
            </div>
            <nav>
              <ol class="space-y-2">
                {headings.filter(h => h.depth <= 2).map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="font-sans text-xs text-ink-muted hover:text-green transition-colors leading-snug block"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>
        )}

        <!-- Über uns -->
        <div>
          <div class="border-b-2 border-ink pb-2 mb-4">
            <p class="font-sans text-xs font-bold uppercase tracking-widest">Über Xperten Insider</p>
          </div>
          <p class="font-sans text-sm text-ink-muted leading-relaxed">
            Insider-Wissen für Unternehmer und Selbstständige. Keine Theorie, keine Floskeln - nur was wirklich funktioniert.
          </p>
        </div>

        <!-- Kategorie -->
        <div>
          <div class="border-b-2 border-ink pb-2 mb-4">
            <p class="font-sans text-xs font-bold uppercase tracking-widest">Kategorie</p>
          </div>
          <a
            href={`/kategorie/${d.kategorie.toLowerCase()}`}
            class="kicker hover:text-green-dark transition-colors"
          >
            {d.kategorie} →
          </a>
        </div>

      </aside>
    </div>

    <!-- Verwandte Artikel -->
    {alle.length > 0 && (
      <section class="mt-16 border-t-2 border-ink pt-8">
        <p class="font-sans text-xs font-bold uppercase tracking-widest border-b border-rule pb-2 mb-6">
          Weitere Artikel zu <span class="text-green">{d.kategorie}</span>
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-0">
          {alle.map((a, i) => (
            <div class={`p-5 ${i < alle.length - 1 ? 'border-r border-rule' : ''}`}>
              <ArticleCard
                title={a.data.title}
                description={a.data.description}
                kategorie={a.data.kategorie}
                datum={a.data.datum}
                slug={a.id}
              />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Navigation -->
    <div class="mt-8 border-t border-rule pt-6">
      <a href="/blog" class="font-sans text-xs font-bold uppercase tracking-widest text-ink hover:text-green transition-colors">
        ← Alle Artikel
      </a>
    </div>

  </main>

  <Footer />
</BaseLayout>
