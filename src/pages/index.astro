---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import { site } from '@data/site';

const allArticles = (await getCollection('blog'))
  .filter((a) => a.data.freigabe)
  .sort((a, b) => b.data.datum.getTime() - a.data.datum.getTime());

const featured = allArticles.find((a) => a.data.featured) ?? allArticles[0];
const rest = allArticles.filter((a) => a.id !== featured?.id).slice(0, 6);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.description,
  inLanguage: 'de-DE',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${site.url}/blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---
<BaseLayout
  title="Business, Marketing & Unternehmertum"
  description={site.description}
  path="/"
  schema={websiteSchema}
>
  <Header />

  <main class="mx-auto max-w-7xl px-4 py-8">

    <!-- Feature of the Day Banner -->
    <div class="border-b-2 border-ink pb-2 mb-6">
      <p style="font-family: 'Barlow Condensed', Impact, sans-serif; font-weight: 900; font-size: clamp(1.4rem, 3vw, 2rem); text-transform: uppercase; letter-spacing: 0.05em;">
        <span style="color: #6abf4b;">Feature</span> of the Day
      </p>
    </div>

    <!-- Hero: Featured + Sidebar -->
    {featured && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-b-2 border-ink pb-8 mb-8">
        <!-- Featured Artikel -->
        <div class="md:col-span-2 md:border-r md:border-rule md:pr-8">
          <ArticleCard
            title={featured.data.title}
            description={featured.data.description}
            kategorie={featured.data.kategorie}
            datum={featured.data.datum}
            slug={featured.id}
            bild={featured.data.bild}
            bildAlt={featured.data.bildAlt}
            featured={true}
          />
        </div>

        <!-- Sidebar: weitere Artikel -->
        <div class="md:pl-8 mt-6 md:mt-0 space-y-5">
          <p class="font-sans text-xs font-bold uppercase tracking-widest border-b border-rule pb-2">
            Weitere Artikel
          </p>
          {rest.slice(0, 3).map((a, i) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              kategorie={a.data.kategorie}
              datum={a.data.datum}
              slug={a.id}
              bild={a.data.bild}
              bildAlt={a.data.bildAlt}
              border={i < 2 ? 'bottom' : 'none'}
            />
          ))}
        </div>
      </div>
    )}

    <!-- Alle Artikel: 3-Spalten Grid -->
    {rest.length > 3 && (
      <section>
        <p class="font-sans text-xs font-bold uppercase tracking-widest border-b-2 border-ink pb-2 mb-6">
          Neueste Beiträge
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-0">
          {rest.slice(3).map((a, i) => (
            <div class={`p-4 ${i % 3 !== 2 ? 'border-r border-rule' : ''} border-b border-rule`}>
              <ArticleCard
                title={a.data.title}
                description={a.data.description}
                kategorie={a.data.kategorie}
                datum={a.data.datum}
                slug={a.id}
                bild={a.data.bild}
                bildAlt={a.data.bildAlt}
              />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Alle Artikel Link -->
    <div class="mt-8 text-center border-t border-rule pt-6">
      <a
        href="/blog"
        class="font-sans text-sm font-bold uppercase tracking-widest text-ink border-2 border-ink px-6 py-2 hover:bg-ink hover:text-sand transition-colors"
      >
        Alle Artikel →
      </a>
    </div>

  </main>

  <Footer />
</BaseLayout>
